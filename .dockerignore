# .dockerignore
# Ignore the following files and directories when building the Docker image

# Ignore the Dockerfile and .dockerignore themselves
Dockerfile
.dockerignore

# Ignore Git-related files
.git
.gitattributes
.gitignore

# Ignore Go build artifacts
*.exe
Makefile
/bin/
/server

# Ignore temporary files
getfiles.txt
*.log

# Ignore scripts
getfiles.sh

# Ignore environment files
.env
.env.example

# Ignore Documentation and markdown files
*.md
LICENSE
